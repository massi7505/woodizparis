# Vercel KV — Ajoutez ces variables dans Vercel Dashboard > Settings > Environment Variables
# Elles sont générées automatiquement quand vous créez un store KV dans Vercel

KV_REST_API_URL=your_kv_rest_api_url_here
KV_REST_API_TOKEN=your_kv_rest_api_token_here
KV_REST_API_READ_ONLY_TOKEN=your_kv_read_only_token_here
